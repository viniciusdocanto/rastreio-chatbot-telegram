{
  "name": "chatbot-telegram",
  "version": "1.1.8",
  "description": "Chatbot for tracking packages in telegram",
  "repository": "https://github.com/viniciusdocanto/rastreio-chatbot-telegram",
  "author": "Vinicius do Canto <viniciusdocanto@users.noreply.github.com>",
  "private": false,
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --exclude **/dist/**",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.66.0",
    "random-js": "^2.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.3.0",
    "prisma": "^5.10.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.2.0",
    "vitest": "^1.6.0"
  },
  "overrides": {
    "form-data": "^2.5.4",
    "qs": "^6.15.0",
    "tough-cookie": "^4.1.3",
    "esbuild": "^0.25.0"
  }
}