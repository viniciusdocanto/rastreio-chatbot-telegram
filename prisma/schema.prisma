generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tracking {
  id            Int      @id @default(autoincrement())
  chatId        String
  code          String
  description   String?
  lastEventDate String?
  userName      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([chatId, code])
}
